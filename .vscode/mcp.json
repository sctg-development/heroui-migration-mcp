{
  "servers": {
    "heroui-migration": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/dist/src/index.js"
      ]
    },
    "heroui-migration-dev": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "${workspaceFolder}/src/index.ts"
      ]
    }
  }
}