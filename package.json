{
  "name": "heroui-migration-mcp",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "MCP server and tooling for HeroUI v2 -> v3 migration, including a faithful HeroUI v2 LLM docs generator.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx --watch src/index.ts",
    "generate:heroui-v2:full": "tsx scripts/generate-heroui-llms-docs.ts --version v2 --full",
    "generate:heroui-v3:full": "tsx scripts/generate-heroui-llms-docs.ts --version v3 --full",
    "inspect": "npx @modelcontextprotocol/inspector node dist/src/index.js",
    "inspect:dev": "npx tsx --watch src/index.ts --run=inspect",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build-corpus": "tsx src/cli/build-corpus.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "build-index": "tsx src/cli/build-index.ts",
    "scan-project": "tsx src/cli/scan-project.ts",
    "audit-tailwind": "tsx src/cli/audit-tailwind.ts",
    "export-code": "tsx src/export-code.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.37.2",
    "yargs": "^18.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^22.13.10",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}